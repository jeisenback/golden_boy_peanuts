# Copy this file to .env and fill in your values. NEVER commit .env to source control.
# All variables are read at runtime via python-dotenv. Reference: ESOD Section 3.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/energy_options

# --- Market Data ---
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY
YFINANCE_API_KEY=YOUR_YFINANCE_API_KEY
POLYGON_API_KEY=YOUR_POLYGON_API_KEY

# --- Supply & Inventory ---
EIA_API_KEY=YOUR_EIA_API_KEY

# --- News & Events ---
NEWSAPI_KEY=YOUR_NEWSAPI_KEY
GDELT_BASE_URL=http://api.gdeltproject.org/api/v2

# --- Insider Activity ---
EDGAR_BASE_URL=https://efts.sec.gov/LATEST/search-index
QUIVER_API_KEY=YOUR_QUIVER_API_KEY

# --- Shipping / Logistics ---
MARINETRAFFIC_API_KEY=YOUR_MARINETRAFFIC_API_KEY

# --- LLM Provider (via src/core/llm_wrapper.py only — never direct in agent code) ---
LLM_PROVIDER=anthropic
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# --- Application Config ---
LOG_LEVEL=INFO
TENACITY_MAX_RETRIES=5
TENACITY_WAIT_MULTIPLIER=1
TENACITY_WAIT_MAX=60
# --- End of template ---
